<%- include('../partials/navbar') %>

<div class="dashboard-header">
  <h2>Dashboard</h2>
  <a href="/create-post" class="btn">Create New Post</a>
</div>

<p>Welcome back, <strong><%= user ? user.name : locals.user.name %></strong>!</p>

<div class="post-list">
  <% if (posts && posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <div class="post-card">
        <h3 class="post-title"><a href="/post/<%= post._id %>"><%= post.title %></a></h3>
        <div class="post-meta">
          By <span><%= post.author.name %></span> | <%= new Date(post.createdAt).toLocaleDateString() %> | Likes: <%= post.likes.length %> | Comments: <%= post.comments.length %>
        </div>
        <p class="post-excerpt">
          <%= post.content.substring(0, 150) %>...
        </p>
        <a href="/post/<%= post._id %>" class="btn" style="padding: 5px 10px; font-size: 0.85rem;">Read More</a>
        
        <% if (locals.user && post.author._id.toString() === locals.user._id.toString()) { %>
          <button class="btn btn-danger delete-post-btn" data-id="<%= post._id %>" style="padding: 5px 10px; font-size: 0.85rem; margin-left: 10px;">Delete</button>
        <% } %>
      </div>
    <% }) %>
  <% } else { %>
    <p>No posts found. Be the first to create one!</p>
  <% } %>
</div>

<script>
  const deleteBtns = document.querySelectorAll('.delete-post-btn');
  deleteBtns.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      if (confirm('Are you sure you want to delete this post?')) {
        const postId = e.target.getAttribute('data-id');
        try {
          const res = await fetch(`/api/posts/${postId}`, {
            method: 'DELETE'
          });
          const data = await res.json();
          if (data.success) {
            window.location.reload();
          } else {
            alert('Error deleting post');
          }
        } catch (err) {
          console.error(err);
          alert('Error deleting post');
        }
      }
    });
  });
</script>

<%- include('../partials/footer') %>
